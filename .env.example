TELEGRAM_TOKEN=
BALE_TOKEN=
BALE_CHAT_ID=

# Logging: DEBUG for development, INFO for production
LOG_LEVEL=INFO

# YouTube cookie auth (to bypass bot detection)
# Option 1: path to a cookies.txt file exported from your browser
YOUTUBE_COOKIES_FILE=cookies.txt
# Option 2: auto-read from browser (chrome, firefox, edge, brave) — works locally only
YOUTUBE_COOKIES_BROWSER=chrome